# ─── Email Notifications (Resend) ───────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create key
# Free tier: 3 000 emails/month, enough for any small restaurant
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives reservation notifications
# Must be a verified domain address on Resend (or the account email on free tier)
RESTAURANT_EMAIL=contact@lepecheur.tn

# ─── Vercel KV Database (Redis) ──────────────────────────────────────────────
# In your Vercel project: Storage → Create Database → KV (Redis)
# These values are auto-filled when you link the KV store to your project.
KV_REST_API_URL=https://xxxxxxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
# The password to access /admin — keep this secret
ADMIN_PASSWORD=change_me_to_something_strong
